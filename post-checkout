#!/bin/bash
# post-checkout hook — 记录 checkout 事件 + 输出 state 摘要 + 更新 STATUS.md

. "$(dirname "$0")/hooks.conf"

PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
DB="$PROJECT_DIR/.ai/project.db"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

[ ! -f "$DB" ] && exit 0

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")
FROM=$(git log -1 --format="%h" --skip=1 2>/dev/null || echo "none")

# 安全构建 JSON
PAYLOAD=$("$AI_HOOKS_PYTHON" -c "
import json, sys
print(json.dumps({'branch': sys.argv[1], 'from': sys.argv[2]}))
" "$BRANCH" "$FROM")

RECORD_OUTPUT=$("$AI_HOOKS_PYTHON" "$(dirname "$0")/record_event.py" "$DB" checkout "$PAYLOAD" "$PROJECT_NAME" 2>/dev/null) || true
EVENT_ID=$(echo "$RECORD_OUTPUT" | "$AI_HOOKS_PYTHON" -c "import sys; s=sys.stdin.read().strip(); print(s.split()[0].split('=')[1] if 'event_id=' in s else '')" 2>/dev/null) || true

if [ -n "$EVENT_ID" ]; then
    "$AI_HOOKS_PYTHON" "$(dirname "$0")/update_state.py" "$DB" checkout "$EVENT_ID" 2>/dev/null || true
fi

"$AI_HOOKS_PYTHON" "$(dirname "$0")/render_state.py" "$DB" --file 2>/dev/null || true

# 输出摘要
echo ""
echo "=== .ai 状态 ==="
"$AI_HOOKS_PYTHON" "$(dirname "$0")/db.py" summary "$DB" 2>/dev/null || true
echo "================"
