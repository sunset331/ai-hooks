#!/bin/bash
# AI_HOOKS_VERSION=3.1.2
# post-commit hook — 记录 commit 事件 + 刷新 state + 更新 STATUS.md

. "$(dirname "$0")/hooks.conf"

PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
DB="$PROJECT_DIR/.ai/project.db"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

[ ! -f "$DB" ] && exit 0

SHA=$(git log -1 --format="%H" 2>/dev/null || echo "unknown")
MSG=$(git log -1 --format="%s" 2>/dev/null || echo "unknown")
DATE=$(git log -1 --format="%ai" 2>/dev/null || echo "unknown")
AUTHOR=$(git log -1 --format="%an" 2>/dev/null || echo "unknown")

# 安全构建 JSON — 用 Python 避免 shell 拼 JSON 导致引号问题
PAYLOAD=$("$AI_HOOKS_PYTHON" -c "
import json, sys
print(json.dumps({
    'sha': sys.argv[1],
    'message': sys.argv[2],
    'date': sys.argv[3],
    'author': sys.argv[4],
}))
" "$SHA" "$MSG" "$DATE" "$AUTHOR")

# record_event 先执行，输出包含 event_id
RECORD_OUTPUT=$("$AI_HOOKS_PYTHON" "$(dirname "$0")/record_event.py" "$DB" commit "$PAYLOAD" "$PROJECT_NAME" 2>/dev/null) || true
EVENT_ID=$(echo "$RECORD_OUTPUT" | "$AI_HOOKS_PYTHON" -c "import sys; s=sys.stdin.read().strip(); print(s.split()[0].split('=')[1] if 'event_id=' in s else '')" 2>/dev/null) || true

if [ -n "$EVENT_ID" ]; then
    "$AI_HOOKS_PYTHON" "$(dirname "$0")/update_state.py" "$DB" commit "$EVENT_ID" 2>/dev/null || true
fi

"$AI_HOOKS_PYTHON" "$(dirname "$0")/render_state.py" "$DB" --file 2>/dev/null || true
echo "OK .ai: commit event recorded, STATUS.md updated"
